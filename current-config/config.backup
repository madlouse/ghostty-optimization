# ============================================================
# Ghostty - AI CLI Development Configuration
# Optimized for: Claude Code / Codex / Gemini CLI
# Device: 16" MacBook Pro
# ============================================================

# --- Font ---
font-family = JetBrainsMono Nerd Font
font-size = 16
font-thicken = true
# Enable ligatures (=> -> != etc.)
font-feature = +calt
font-feature = +liga
# Slightly increase line height for readability
adjust-cell-height = 2

# --- Theme ---
# Auto light/dark switching based on macOS appearance
theme = light:Catppuccin Latte,dark:Catppuccin Mocha

# --- Window ---
window-padding-x = 14
window-padding-y = 10
window-padding-balance = true
macos-titlebar-style = transparent
window-save-state = always
window-inherit-working-directory = true
window-inherit-font-size = true
window-new-tab-position = current
confirm-close-surface = true

# --- Cursor ---
cursor-style = bar
cursor-style-blink = false

# --- Scrollback (10MB - AI tools produce lots of output) ---
scrollback-limit = 10000000

# --- Clipboard ---
clipboard-read = allow
clipboard-write = allow
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
copy-on-select = clipboard

# --- Input ---
mouse-hide-while-typing = true

# --- Shell Integration ---
shell-integration = detect
shell-integration-features = cursor,sudo,title

# --- Unicode / Emoji (important for AI CLI output) ---
grapheme-width-method = unicode

# --- Splits ---
unfocused-split-opacity = 0.75

# --- Quick Terminal (Ctrl+` global hotkey) ---
keybind = global:ctrl+grave_accent=toggle_quick_terminal
quick-terminal-position = top
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.15
quick-terminal-autohide = true

# --- Custom Keybindings ---
# Split navigation
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom
# Split creation
keybind = super+alt+d=new_split:right
keybind = super+alt+shift+d=new_split:down
# Split management
keybind = super+alt+enter=toggle_split_zoom
keybind = super+alt+equal=equalize_splits
# Clear screen
keybind = super+k=clear_screen
