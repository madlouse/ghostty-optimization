{
  "theme": "Catppuccin Mocha",
  "ui_font_size": 15,
  "buffer_font_size": 15,
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_features": {
    "calt": true,
    "liga": true
  },
  "terminal": {
    "font_size": 15,
    "font_family": "JetBrainsMono Nerd Font",
    "env": {
      "TERM": "xterm-256color"
    }
  },
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "format_on_save": "off",
  "tab_size": 2,
  "soft_wrap": "editor_width"
}
