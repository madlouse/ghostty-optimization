# =============================================================
# ~/.zshrc — Portable Zsh configuration
# 跨机器设计：不硬编码本地路径，通过动态检测适配不同环境
# =============================================================

# ---- Homebrew (Apple Silicon / Intel 自动适配) ----
if [[ -f /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"       # Apple Silicon
elif [[ -f /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"           # Intel Mac
fi
BREW_PREFIX="$(brew --prefix 2>/dev/null || echo /opt/homebrew)"

# ---- PATH 基础 ----
export PATH="$HOME/bin:/usr/local/bin:$PATH"

# ---- oh-my-zsh ----
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="agnoster"
plugins=(git)
[[ -f "$ZSH/oh-my-zsh.sh" ]] && source "$ZSH/oh-my-zsh.sh"

# ---- Zsh 插件（条件加载，不硬编码路径）----
[[ -f "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh" ]] && \
  source "$BREW_PREFIX/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh"

[[ -f "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]] && \
  source "$BREW_PREFIX/share/zsh-autosuggestions/zsh-autosuggestions.zsh"

# ---- opencli completion ----
[[ -d "$HOME/.zsh/completions" ]] && fpath=($HOME/.zsh/completions $fpath)
[[ -f "$HOME/.openclaw/completions/openclaw.zsh" ]] && \
  source "$HOME/.openclaw/completions/openclaw.zsh"

# ---- Homebrew 国内镜像清除（使用官方源）----
unset HOMEBREW_BREW_GIT_REMOTE
unset HOMEBREW_CORE_GIT_REMOTE
unset HOMEBREW_BOTTLE_DOMAIN
unset HOMEBREW_API_DOMAIN

# ---- Secrets（不进 git，本地独立管理）----
# 创建 ~/.env.local 写入私钥，格式：export KEY=value
[[ -f "$HOME/.env.local" ]] && source "$HOME/.env.local"

# ---- Pyenv ----
if command -v pyenv &>/dev/null; then
  export PYENV_ROOT="$HOME/.pyenv"
  export PATH="$PYENV_ROOT/bin:$PATH"
  eval "$(pyenv init -)"
fi

# ---- Bun ----
if [[ -d "$HOME/.bun" ]]; then
  export BUN_INSTALL="$HOME/.bun"
  export PATH="$BUN_INSTALL/bin:$PATH"
  [[ -s "$HOME/.bun/_bun" ]] && source "$HOME/.bun/_bun"
fi

# ---- node@20 (Codex 专用，如果安装了才加) ----
[[ -d "$BREW_PREFIX/opt/node@20/bin" ]] && \
  export PATH="$BREW_PREFIX/opt/node@20/bin:$PATH"

# ---- opencode ----
[[ -d "$HOME/.opencode/bin" ]] && export PATH="$HOME/.opencode/bin:$PATH"

# ---- Antigravity ----
[[ -d "$HOME/.antigravity/antigravity/bin" ]] && \
  export PATH="$HOME/.antigravity/antigravity/bin:$PATH"

# ---- agent-cli-api bootstrap ----
if [ -z "${AGENT_CLI_API_HOME:-}" ]; then
  if command -v brew &>/dev/null && brew --prefix agent-cli-api &>/dev/null 2>&1; then
    export AGENT_CLI_API_HOME="$(brew --prefix agent-cli-api)/libexec"
  elif [[ -d "$BREW_PREFIX/opt/agent-cli-api/libexec" ]]; then
    export AGENT_CLI_API_HOME="$BREW_PREFIX/opt/agent-cli-api/libexec"
  fi
fi
[[ -f "$AGENT_CLI_API_HOME/shell/init.zsh" ]] && source "$AGENT_CLI_API_HOME/shell/init.zsh"

# ---- Claude Code quick modes ----
if command -v claude &>/dev/null; then
  alias ccp='claude --permission-mode plan'
  alias ccd='claude --permission-mode default'
  alias cca='claude --permission-mode acceptEdits'
fi

# ---- Zed ----
command -v zed &>/dev/null && alias z="zed" && alias z.="zed ."

# ---- glow ----
command -v glow &>/dev/null && alias glow="glow --style notty"

# ---- Cmux shell 集成 + 快捷函数 ----
if command -v cmux &>/dev/null; then
  # cmux 通过 CMUX_SOCKET_PATH 自动集成，无需 shell init

  # 快速新建项目 Workspace
  cw() {
    local name="${1:-$(basename "$PWD")}"
    cmux new-workspace --name "$name" 2>/dev/null
    echo "Workspace '$name' created"
  }

  # 在当前 workspace 右侧分屏并启动 Claude Code
  cc() {
    cmux new-split right 2>/dev/null
    cmux send --surface last "claude" 2>/dev/null
    cmux send-key --surface last "Return" 2>/dev/null
  }

  # 在 Cmux 中打开内置浏览器
  cb() {
    local url="${1:-http://localhost:3000}"
    cmux new-pane --type browser --url "$url" 2>/dev/null
  }
fi

# ---- opencli CDP ----
export OPENCLI_CDP_ENDPOINT="${OPENCLI_CDP_ENDPOINT:-http://localhost:9222}"
if command -v opencli &>/dev/null || [[ -d "$BREW_PREFIX/lib/node_modules/@jackwener/opencli" ]]; then
  alias chrome-cdp='open -n /Applications/Google\ Chrome.app --args \
    --remote-debugging-port=9222 \
    --user-data-dir=$HOME/.chrome-debug-profile \
    --profile-directory=Default \
    --load-extension=$(brew --prefix)/lib/node_modules/@jackwener/opencli/extension \
    --no-first-run --no-default-browser-check \
    --disable-session-crashed-bubble --hide-crash-restore-bubble \
    --disable-features=ProfilePicker'
fi

# ---- Starship prompt（最后加载，覆盖 oh-my-zsh theme）----
command -v starship &>/dev/null && eval "$(starship init zsh)"

# ---- 本机专属配置（不进 git）----
# 在 ~/.zshrc.local 中写入机器相关别名、路径、项目快捷方式等
# 例如：alias teams='/path/to/your/teams/script.sh'
#       alias rd3="uv run ~/code/reader3/reader3.py"
[[ -f "$HOME/.zshrc.local" ]] && source "$HOME/.zshrc.local"
